# syntax=docker/dockerfile:1.7

# Copy-only Dockerfile. No compilation; binaries come from the workflow's
# matrix build job. Drastically faster than rebuilding from source.
#
# Phase 3-5 cutover (2026-05-22): the build context's ./prebuilt-bins/
# directory now contains exactly ONE real binary (`hawcx-manager`) plus
# 7 symlinks under legacy names (haap-authenticator, haap-tqs-precompute,
# haap-tqs-jit, haap-assembler, haap-eib, haap-supervisor, haap-sdk).
# The symlinks are generated by the matrix-build job's `Stage Docker
# binaries` step BEFORE the docker-bins artifact is uploaded, so they
# arrive here intact. `COPY` preserves symlink structure.
#
# See /hx_agent_canonical_spec/DESIGN-MEMO-MULTICALL-BINARY.md for the
# argv0 dispatch design.

FROM gcr.io/distroless/cc-debian12

LABEL org.opencontainers.image.source="https://github.com/hawcx/hawcx_agentic_sdk"
LABEL org.opencontainers.image.description="HAAP SDK runtime (hawcx-manager multi-call binary + 7 legacy-name symlinks; haap-rsv ships from ghcr.io/hawcx/haap-rsv)"

# 2026-05-21: haap-rsv removed from this image. The MCP-server-side
# verifier sidecar ships from hx_agent_authorizer/Dockerfile as a
# separate image at ghcr.io/hawcx/haap-rsv. Customers who run the
# verifier alongside the supervisor pull both images.
#
# 2026-05-22 (Phase 3-5): single COPY of the pre-staged tree replaces
# the prior 7 per-binary COPY lines. Symlinks are made at packaging
# time on the matrix runner (release.yml `Stage Docker binaries`),
# not here.
COPY prebuilt-bins/ /usr/local/bin/

# Default entrypoint = haap-supervisor (symlink to hawcx-manager);
# argv[0] routes to supervisor mode via the multi-call dispatcher.
ENTRYPOINT ["/usr/local/bin/haap-supervisor"]
