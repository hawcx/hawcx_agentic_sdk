{
  "name": "@hawcx/hawcx-haap",
  "version": "0.1.0-alpha.12",
  "description": "Customer SDK for the Hawcx Agent Authentication Protocol (HAAP). Connects to a customer-deployed haap-supervisor and proxies tool calls through the Assembler per CS v7.2.5 Profile E.",
  "keywords": [
    "haap",
    "hawcx",
    "agent",
    "authentication",
    "mcp",
    "tbac"
  ],
  "homepage": "https://github.com/hawcx/hawcx_agentic_sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hawcx/hawcx_agentic_sdk.git",
    "directory": "node"
  },
  "bugs": "https://github.com/hawcx/hawcx_agentic_sdk/issues",
  "license": "Apache-2.0",
  "author": "Hawcx Inc.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist coverage"
  },
  "optionalDependencies": {
    "@hawcx/hawcx-haap-linux-x64": "0.1.0-alpha.12",
    "@hawcx/hawcx-haap-linux-arm64": "0.1.0-alpha.12",
    "@hawcx/hawcx-haap-darwin-arm64": "0.1.0-alpha.12",
    "@hawcx/hawcx-haap-win32-x64": "0.1.0-alpha.12",
    "@hawcx/hawcx-haap-win32-arm64": "0.1.0-alpha.12"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
